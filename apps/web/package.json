    "@uploadthing/react": "^7.3.3",
    "@workspace/auth": "workspace:*",
    "@workspace/api-runtime": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/api": "workspace:*",
    "@workspace/contracts": "workspace:*",
    "@workspace/server-primitives": "workspace:*",
    "@workspace/transactional": "workspace:*",
    "@workspace/ui": "workspace:*",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.4",
    "recharts": "3.8.0",
    "server-only": "^0.0.1",
    "shadcn": "^4.13.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "uploadthing": "^7.7.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@workspace/typescript-config": "workspace:*",
    "auth": "^1.6.23",
    "typescript": "^5",
    "vitest": "^4.1.10"

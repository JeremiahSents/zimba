    "db:seed": "pnpm --filter @workspace/db db:seed",
    "db:reset": "pnpm --filter @workspace/db db:reset",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check:ci": "biome check .",
    "check": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@hugeicons/core-free-icons": "^4.2.2",
